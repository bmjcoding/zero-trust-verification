{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zero-trust-verification/schema/verification-manifest/v1",
  "title": "Verification Manifest v1",
  "description": "Structure-only schema (manifest spec §2 layering). Enforces types, enums, ID regexes, required/optional per §3, incomplete_fields-iff-incomplete, spec_hash-iff-complete, and the absence-when-null step constraints (§4). The §10 completeness rules (presence of emission/idempotency/GWT, CORE confirmation, dangling refs, etc.) live in the validator, NOT here, so an incomplete manifest is always schema-valid.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "manifest_revision",
    "spec",
    "completeness",
    "observability",
    "environments",
    "journeys",
    "behaviors"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "manifest_revision": { "type": "integer", "minimum": 1 },
    "spec": {
      "type": "object",
      "required": ["path", "title"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "spec_hash": { "type": "string", "pattern": "^sha256:[0-9a-f]{64}$" }
      },
      "additionalProperties": true
    },
    "completeness": { "enum": ["complete", "incomplete"] },
    "incomplete_fields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "observability": {
      "type": "object",
      "required": ["profile"],
      "properties": { "profile": { "type": "string", "minLength": 1 } },
      "additionalProperties": true
    },
    "environments": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "interrogation": {
      "type": "object",
      "properties": {
        "adrs": { "type": "array", "items": { "type": "string" } },
        "log": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "summary", "resolved_by"],
            "properties": {
              "id": { "type": "string", "pattern": "^DL-[0-9]{3}$" },
              "summary": { "type": "string", "minLength": 1 },
              "resolved_by": { "enum": ["agent", "human"] },
              "dissent": { "type": "string" },
              "exchange_ref": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "journeys": { "type": "array", "items": { "$ref": "#/$defs/journey" } },
    "behaviors": { "type": "array", "items": { "$ref": "#/$defs/behavior" } }
  },
  "allOf": [
    {
      "if": { "properties": { "completeness": { "const": "complete" } } },
      "then": { "required": ["spec"], "properties": { "spec": { "required": ["spec_hash"] } } }
    },
    {
      "if": { "properties": { "completeness": { "const": "incomplete" } } },
      "then": { "required": ["incomplete_fields"], "properties": { "incomplete_fields": { "minItems": 1 } } },
      "else": { "properties": { "incomplete_fields": { "maxItems": 0 } } }
    }
  ],
  "$defs": {
    "journeyId": { "type": "string", "pattern": "^J-[a-z0-9]+(-[a-z0-9]+)*-[0-9]{3}$" },
    "behaviorId": { "type": "string", "pattern": "^B-[a-z0-9]+(-[a-z0-9]+)*-[0-9]{3}$" },
    "criticality": { "enum": ["CORE", "SUPPORTING", "DEV"] },
    "confirmation": { "enum": ["confirmed", "proposed"] },
    "lifecycle": { "enum": ["active", "withdrawn"] },
    "confirmedBy": { "type": "string", "pattern": "^DL-[0-9]{3}$" },
    "controlLocus": { "enum": ["app", "gateway", "mesh", "sidecar", "db-config", "vault", "kms", "ops", "none-declared"] },
    "resilienceMechanism": { "enum": ["breaker", "fail-fast", "bulkhead", "shed", "none-declared"] },
    "journey": {
      "type": "object",
      "required": ["id", "name", "lifecycle", "criticality", "confirmation", "steps"],
      "properties": {
        "id": { "$ref": "#/$defs/journeyId" },
        "name": { "type": "string", "minLength": 1 },
        "lifecycle": { "$ref": "#/$defs/lifecycle" },
        "withdrawn_reason": { "type": "string" },
        "criticality": { "$ref": "#/$defs/criticality" },
        "criticality_reason": { "type": "string" },
        "confirmation": { "$ref": "#/$defs/confirmation" },
        "confirmed_by": { "$ref": "#/$defs/confirmedBy" },
        "abuse_controls": {
          "type": "object",
          "description": "SD-01/ADR 0021: declared locus for this journey's abuse controls (rate limiting). Additive-optional; the audit VERIFIES only locus:app and reports every other locus out-of-scope-by-declaration.",
          "required": ["locus"],
          "properties": {
            "locus": { "$ref": "#/$defs/controlLocus" },
            "note": { "type": "string" }
          },
          "additionalProperties": true
        },
        "steps": { "type": "array", "items": { "$ref": "#/$defs/step" } }
      },
      "additionalProperties": true
    },
    "behavior": {
      "type": "object",
      "required": ["id", "title", "lifecycle", "confirmation", "given", "when", "then"],
      "properties": {
        "id": { "$ref": "#/$defs/behaviorId" },
        "title": { "type": "string", "minLength": 1 },
        "lifecycle": { "$ref": "#/$defs/lifecycle" },
        "withdrawn_reason": { "type": "string" },
        "journey": { "$ref": "#/$defs/journeyId" },
        "criticality": { "$ref": "#/$defs/criticality" },
        "confirmation": { "$ref": "#/$defs/confirmation" },
        "confirmed_by": { "$ref": "#/$defs/confirmedBy" },
        "given": { "type": "string" },
        "when": { "type": "string" },
        "then": { "type": "string" },
        "test_name_hint": { "type": "string" }
      },
      "additionalProperties": true
    },
    "step": {
      "type": "object",
      "required": ["name", "vital_class"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "vital_class": { "enum": ["money", "state-transition", "external-side-effect", "auth", null] },
        "required_emission": { "enum": ["OBSERVED", "LOG-ONLY"] },
        "event_name": { "type": "string" },
        "resilience_posture": {
          "type": "object",
          "description": "SD-01/ADR 0021: declared locus + mechanism for this step's resilience posture (breakers/shed/bulkheads). Additive-optional; VERIFIED only at locus:app.",
          "required": ["locus"],
          "properties": {
            "locus": { "$ref": "#/$defs/controlLocus" },
            "mechanism": { "$ref": "#/$defs/resilienceMechanism" }
          },
          "additionalProperties": true
        },
        "isolation_requirement": {
          "type": "object",
          "description": "SD-01/ADR 0021: declared locus + level for this money-write's transaction isolation. Additive-optional; VERIFIED only at locus:app (db-config/none-declared -> out-of-scope-by-declaration).",
          "required": ["locus"],
          "properties": {
            "locus": { "$ref": "#/$defs/controlLocus" },
            "level": { "type": "string" }
          },
          "additionalProperties": true
        },
        "timeout_budget_ms": {
          "type": "integer",
          "minimum": 0,
          "description": "SD-01/ADR 0021: declared per-step timeout budget in ms (SD §3.7). Additive-optional; in-repo so verified deterministically-in-the-join against the discovered configured timeout — no locus (per-call timeouts are greppable)."
        },
        "alert_seam": {
          "type": "object",
          "properties": { "default": { "enum": ["paged", "dashboard-only", "none"] } },
          "additionalProperties": { "enum": ["paged", "dashboard-only", "none"] }
        },
        "idempotency": {
          "type": "object",
          "required": ["required"],
          "properties": {
            "required": { "type": "boolean" },
            "mechanism": { "enum": ["idempotency-key", "duplicate-guard", "upsert", "transactional-outbox", "not-needed"] },
            "justification": { "type": "string" }
          },
          "additionalProperties": true
        },
        "compensation": {
          "type": "object",
          "oneOf": [
            { "required": ["ref"], "not": { "required": ["none_reason"] } },
            { "required": ["none_reason"], "not": { "required": ["ref"] } }
          ],
          "properties": {
            "ref": { "$ref": "#/$defs/journeyId" },
            "none_reason": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": true
        }
      },
      "allOf": [
        {
          "if": { "properties": { "vital_class": { "const": null } } },
          "then": {
            "allOf": [
              { "not": { "required": ["required_emission"] } },
              { "not": { "required": ["alert_seam"] } },
              { "not": { "required": ["event_name"] } }
            ]
          }
        }
      ],
      "additionalProperties": true
    }
  }
}
